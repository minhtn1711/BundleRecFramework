{
  "model": "crosscbr",
  "dataset": "youshu",
  "data_dir": "data/processed/youshu",

  "implementation": "self_contained_adopted",

  "epochs": 100,
  "batch_size": 2048,
  "embedding_dim": 64,
  "embedding_size": 64,

  "lr": 0.001,
  "weight_decay": 0.0001,
  "l2_reg": 0.0001,
  "optimizer_weight_decay": 0.0001,

  "neg_num": 1,
  "num_layers": 1,

  "aug_type": "ED",
  "ed_interval": 1,
  "item_level_ratio": 0.2,
  "bundle_level_ratio": 0.2,
  "bundle_agg_ratio": 0.2,

  "c_lambda": 0.04,
  "c_temp": 0.25,

  "topk": [10, 20, 40, 80],
  "main_metric": "Recall@20",
  "eval_interval": 5,

  "drop_last": true,
  "num_workers": 2,
  "device": "cuda",
  "seed": 2026,

  "save_dir": "checkpoints"
}
